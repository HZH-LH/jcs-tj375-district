# Preserve deployable artifacts byte-for-byte.
*.bit -text
*.hex -text
*.bin -text
*.elf -text

# Keep HDL and project files as text without rewriting existing line endings.
*.v text eol=lf
*.sv text eol=lf
*.vh text eol=lf
*.svh text eol=lf
*.sdc text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
